SECRET_KEY=change-this-to-a-strong-random-key-in-production
SESSION_EXPIRE_HOURS=8
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
BACKUP_DIR=./backups

# Base de datos - Desarrollo local usa SQLite, QA/Prod usan PostgreSQL en Neon
# Desarrollo local (SQLite):
DATABASE_URL=sqlite:///./iso27001.db

# QA/Produccion (Neon PostgreSQL) - Configurar en Render Environment Variables:
# DATABASE_URL=postgresql://neondb_owner:***@ep-cold-forest-acp1td9k-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require
