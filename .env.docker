# ISO 27001 Evaluator - Variables de Ambiente para Docker
# Copiar este archivo a .env y ajustar los valores

# ============================================
# Seguridad
# ============================================
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambiar-esto-en-produccion-por-una-clave-segura-aleatoria

# ============================================
# Base de Datos (PostgreSQL)
# ============================================
DB_USER=iso27001
DB_PASSWORD=iso27001_secure_password_change_me
DB_PORT=5432

# ============================================
# IA - Ollama (Local)
# ============================================
AI_MODE=ollama
AI_MODEL=meta/llama-3.1-70b-instruct
AI_LOCAL_URL=http://ollama:11434
AI_LOCAL_MODEL=llama3.1:latest
OLLAMA_PORT=11434

# ============================================
# IA - NVIDIA NIM (Opcional - Fallback)
# ============================================
# Obtener API key en: https://build.nvidia.com/
NVIDIA_API_KEY=

# ============================================
# Aplicación
# ============================================
APP_PORT=8000
SESSION_EXPIRE_HOURS=8
MAX_UPLOAD_SIZE_MB=10
ENVIRONMENT=production

# ============================================
# Notas:
# ============================================
# 1. Para producción, cambiar SECRET_KEY y DB_PASSWORD
# 2. Para usar NVIDIA como fallback, configurar NVIDIA_API_KEY
# 3. Los puertos se pueden cambiar según necesidad
# 4. ENVIRONMENT: production | development | qa
